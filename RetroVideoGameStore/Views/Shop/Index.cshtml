@model IEnumerable<RetroVideoGameStore.Models.Category>

@{
    ViewData["Title"] = "Shop Our Store";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Choose Any Category</h1>

<section class="row card-group">
    @foreach (var c in Model)
    {
        <div class="col-sm-6 col-lg-4 mb-3">
            <div class="card mb-4 text-center h-100">
                <div class="card-body">
                    <a asp-asp-controller="Shop" asp-action="Browse" asp-route-itemid="@c.Id">@c.Name</a>
                </div>
            </div>
        </div>
    }
</section>