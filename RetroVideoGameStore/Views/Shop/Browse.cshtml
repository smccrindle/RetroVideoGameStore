@model IEnumerable<RetroVideoGameStore.Models.Product>

<h1>Check out our great products!</h1>

<section class="row card-group">
    @foreach (var p in Model)
    {
        <div class="col-sm-6 col-lg-4 mb-3">
            <div class="card mb-4 text-center h-100">
                <div class="card-body">
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="h5">@p.Name</a>
                    <h6>@String.Format("{0:c}", p.Price)</h6>
                    @if (p.Photo != null)
                    {
                        <img src="~/img/product-uploads/@p.Photo" class="thumb" alt="Product image" />
                    }
                    <form method="post" action="/Shop/AddToCart">
                        <div class="form-group mt-4">
                            <label class="control-label" for="Quantity">Quantity:</label>
                            <input class="form-control form-control-sm w-50" name="Quantity" id="Quantity" required min="1" max="99999" type="number" />
                            <input name="ProductId" id="ProductId" type="hidden" value="@p.Id" />
                            <button class="btn btn-primary mt-1">Add to Cart</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</section>
