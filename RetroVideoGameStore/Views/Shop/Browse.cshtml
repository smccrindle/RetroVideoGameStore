@model IEnumerable<RetroVideoGameStore.Models.Product>

@{
    ViewData["Title"] = "Browse Products by Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Browse Products by Category</h1>

<section class="row card-group">
    @foreach (var p in Model)
    {
        <div class="col-sm-6 col-lg-4 mb-3">
            <div class="card mb-4 text-center h-100">
                <div class="card-body">
                    <h5>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id">@p.Name</a>
                    </h5>
                    @if (p.Photo != null)
                    {
                        <img src="~/img/product-uploads/@p.Photo" alt="Game box for @p.Name" class="img-thumb mt-2 mb-2" />
                    }
                    <h6>@String.Format("{0:c}", p.Price)</h6>
                    <form method="post" action="/Shop/AddToCart">
                        <div class="form-group mt-4 d-flex flex-column align-items-center">
                            <label class="control-label" for="Quantity">Quantity:</label>
                            <input class="form-control form-control-sm w-25 text-center" name="Quantity" id="Quantity" required min="1" max="99999" type="number" />
                            <input name="ProductId" id="ProductId" type="hidden" value="@p.Id" />
                            <button class="btn btn-primary mt-1">Add to Cart</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</section>