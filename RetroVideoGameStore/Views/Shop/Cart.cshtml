@model IEnumerable<RetroVideoGameStore.Models.Cart>

@{
    ViewData["Title"] = "Your Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
    double total = 0;
}

<h1>Your Cart</h1>

@if (Model.Count() == 0)
{
    <h2>There are no items in your cart at the moment.</h2>
    <a asp-action="Index" class="btn btn-primary">Start shopping</a>
}
else
{
    <table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Product)
            </th>
            <th></th>
            <th class="text-end">
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th class="text-end">
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        total += (@item.Price * @item.Quantity);
            <tr>
            <td>
                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.Product.Name</a>
            </td>
            <td>
                @if (item.Product.Photo != null)
                {
                    <img src="~/img/product-uploads/@item.Product.Photo" alt="Product image" class="thumb" />
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>

            <td class="text-end">
                @String.Format("{0:c}", item.Price)
            </td>
            <td>
                <a asp-action="RemoveFromCart" asp-route-id="@item.Id" onclick="return confirm('Are you sure you want to delete this item?')">Delete</a>
            </td>
        </tr>
}
        <tr>
            <td colspan="3">
                <a asp-action="Index" class="btn btn-primary">Keep shopping</a>
            </td>
            <td class="text-end">
                @String.Format("{0:c}", total)
            </td>
            <td class="text-end">
                <a asp-action="Checkout" class="btn btn-primary">Checkout</a>
            </td>
        </tr>
    </tbody>
</table>
}
